  "components": {
    "schemas": {
      "AccountType": {
        "enum": [
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "ApplicationStatus": {
        "enum": [
          0,
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      },
      "CreateApplicationDto": {
        "type": "object",
        "properties": {
          "opportunityId": {
            "type": "integer",
            "format": "int32"
          },
          "notes": {
            "maxLength": 1000,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateOpportunityDto": {
        "required": [
          "capacity",
          "endDate",
          "startDate",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 200,
            "minLength": 2,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "capacity": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "maxLength": 300,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "DecisionDto": {
        "type": "object",
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/ApplicationStatus"
          }
        },
        "additionalProperties": false
      },
      "LoginDTO": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterDTO": {
        "required": [
          "email",
          "fullName",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "fullName": {
            "minLength": 1,
            "type": "string"
          },
          "accountType": {
            "$ref": "#/components/schemas/AccountType"
          },
          "level": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "gpa": {
            "maximum": 4,
            "minimum": 0,
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "address": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "maxLength": 50,
            "type": "string",
            "format": "tel",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateInstitutionDto": {
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 200,
            "minLength": 2,
            "type": "string",
            "nullable": true
          },
          "address": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "maxLength": 50,
            "type": "string",
            "format": "tel",
            "nullable": true
          },
          "email": {
            "maxLength": 150,
            "type": "string",
            "format": "email",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateStudentDto": {
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "level": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "type": "string",
            "format": "tel",
            "nullable": true
          },
          "gpa": {
            "maximum": 4,
            "minimum": 0,
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "bio": {
            "maxLength": 1000,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}